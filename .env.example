# SpritEXAI Pay — core engine configuration.
# Copy to .env and set real secrets before running in anything but local dev.

PORT=8080
DATABASE_URL=sqlite://spritexai_pay.db?mode=rwc

# Rotate these independently. Generate with: openssl rand -hex 32
SMS_HMAC_SECRET=change-me-inbound-sms-secret
WEBHOOK_HMAC_SECRET=change-me-outbound-webhook-secret

# Optional — only needed for multi-instance / Cloud deployments.
# REDIS_URL=redis://localhost:6379

# Log filter (tracing EnvFilter syntax).
RUST_LOG=info,spritexai_pay=debug
